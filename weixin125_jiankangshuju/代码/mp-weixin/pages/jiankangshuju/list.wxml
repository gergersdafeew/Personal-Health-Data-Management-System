<mescroll-uni vue-id="62cd3912-1" up="{{upOption}}" down="{{downOption}}" data-event-opts="{{[['^init',[['mescrollInit']]],['^down',[['downCallback']]],['^up',[['upCallback']]]]}}" bind:init="__e" bind:down="__e" bind:up="__e" bind:__l="__l" vue-slots="{{['default']}}">
  <view class="cu-bar bg-white search" style="{{'top:'+(CustomBar+'px')+';'}}">
    <view class="search-form round" style="flex:1;">
      <text class="cuIcon-search"></text>
      <input type="text" placeholder="用户账号" data-event-opts="{{[['input',[['__set_model',['$0','yonghuzhanghao','$event',[]],['searchForm']]]]]}}" value="{{searchForm.yonghuzhanghao}}" bindinput="__e"/>
    </view>
    <view class="action">
      <button class="cu-btn shadow-blur round" style="background-color:{{btnColor[0]}};color:#fff;" data-event-opts="{{[['tap',[['search',['$event']]]]]}}" bindtap="__e">搜索</button>
    </view>
  </view>
  <view class="uni-product-list">
    <block wx:for="{{list}}" wx:for-item="product" wx:for-index="index" wx:key="id">
      <view data-event-opts="{{[['tap',[['onDetailTap',['$0'],[[['list','',index]]]]]]]}}" class="uni-product" bindtap="__e">
        <view class="uni-product-title">{{product.yonghuming}}</view>
        <view class="image-view">
          <image class="uni-product-image" mode="aspectFill" src="{{product.thumb}}"></image>
        </view>
        <view style="display:flex;justify-content:space-between;">
          <block wx:if="{{canEdit}}"><text class="cuIcon-edit" catchtap="__e" data-event-opts="{{[['tap',[['onUpdateTap',['$0'],[[['list','',index,'id']]]]]]]}}">修改</text></block>
          <block wx:if="{{canDelete}}"><text class="cuIcon-delete" catchtap="__e" data-event-opts="{{[['tap',[['onDeleteTap',['$0'],[[['list','',index,'id']]]]]]]}}">删除</text></block>
        </view>
      </view>
    </block>
  </view>
  <block wx:if="{{canAdd}}">
    <button class="add-btn" style="background-color:#409EFF;color:#fff;width:80%;" data-event-opts="{{[['tap',[['onAddTap']]]]}}" bindtap="__e">新增</button>
  </block>
</mescroll-uni>
