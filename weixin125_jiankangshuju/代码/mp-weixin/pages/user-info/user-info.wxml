<view class="page">
  <view class="form-card">
    <view class="form-item">
      <text class="label">用户账号</text>
      <input class="input readonly" value="{{ruleForm.yonghuzhanghao}}" disabled />
    </view>
    <view class="form-item">
      <text class="label">密码</text>
      <input class="input" password value="{{ruleForm.mima}}" placeholder="请输入密码" data-field="mima" bindinput="onInput" />
    </view>
    <view class="form-item">
      <text class="label">用户名</text>
      <input class="input" value="{{ruleForm.yonghuming}}" placeholder="请输入用户名" data-field="yonghuming" bindinput="onInput" />
    </view>
    <view class="form-item">
      <text class="label">性别</text>
      <picker range="{{xingbieOptions}}" value="{{xingbieIndex}}" bindchange="onXingbieChange">
        <view class="picker">{{ruleForm.xingbie || '请选择性别'}}</view>
      </picker>
    </view>
    <view class="form-item">
      <text class="label">联系电话</text>
      <input class="input" type="number" value="{{ruleForm.lianxidianhua}}" placeholder="请输入联系电话" data-field="lianxidianhua" bindinput="onInput" />
    </view>
    <view class="form-item">
      <text class="label">账号状态</text>
      <view class="status {{ruleForm.zhuangtai === '禁用' ? 'disabled' : 'normal'}}">{{ruleForm.zhuangtai || '正常'}}</view>
    </view>
    <view class="form-item avatar-item">
      <text class="label">个人头像</text>
      <view class="avatar-box" bindtap="chooseAvatar">
        <image class="avatar" src="{{ruleForm.gerentouxiang || '/static/center/face.jpeg'}}" mode="aspectFill"></image>
        <text class="avatar-tip">点击更换</text>
      </view>
    </view>
  </view>

  <button class="btn primary" bindtap="onSave">保存修改</button>
  <button class="btn logout" bindtap="onLogout">退出登录</button>
</view>
