page {
  background-color: #f1f1f1;
}

.content {
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #4ad1f2, #26c6da);
  width: 100%;
  padding: 48rpx 32rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.userinfo {
  display: flex;
  align-items: center;
  flex: 1;
}

.face {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
}

.info {
  margin-left: 24rpx;
}

.username {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

.sub {
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
  margin-top: 8rpx;
}

.status-tag {
  display: inline-block;
  margin-top: 12rpx;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.status-tag.normal {
  color: #fff;
  background: rgba(103, 194, 58, 0.35);
}

.status-tag.disabled {
  color: #fff;
  background: rgba(245, 108, 108, 0.45);
}

.edit-tip {
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  flex-shrink: 0;
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  margin: -30rpx 24rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  padding: 24rpx 0;
  position: relative;
  z-index: 2;
}

.quick-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 24rpx;
  color: #333;
}

.quick-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.section-title {
  padding: 0 32rpx 16rpx;
  font-size: 28rpx;
  color: #909399;
}

.list {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.li {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 30rpx;
  color: #333;
}

.li:last-child {
  border-bottom: none;
}

.hover {
  background: #f5f7fa;
}

.arrow {
  color: #c0c4cc;
}

.logout-btn {
  margin: 40rpx 24rpx 0;
  background: #fff;
  color: #f56c6c;
  border: 1rpx solid #fbc4c4;
  border-radius: 44rpx;
  font-size: 30rpx;
}
