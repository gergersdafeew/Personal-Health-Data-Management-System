.container {
  padding: 24rpx;
  padding-bottom: 140rpx;
  background: #f5f5f5;
  min-height: 100vh;
}
.post-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,.08);
}
.post-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  margin-bottom: 16rpx;
}
.post-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}
.post-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}
.post-status {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #4AD1F2;
}
.reply-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}
.reply-item {
  padding: 20rpx 0;
  border-bottom: 1rpx dashed #eee;
}
.reply-user {
  font-size: 26rpx;
  color: #4AD1F2;
  margin-bottom: 6rpx;
}
.reply-time {
  font-size: 22rpx;
  color: #bbb;
  margin-bottom: 10rpx;
}
.reply-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}
.empty-reply {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,.06);
}
.reply-btn {
  background: #4AD1F2;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
}
