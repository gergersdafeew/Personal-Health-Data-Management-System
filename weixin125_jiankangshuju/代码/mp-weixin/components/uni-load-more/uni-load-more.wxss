.uni-load-more {
  display: flex;
  flex-direction: row;
  height: 40px;
  align-items: center;
  justify-content: center;
}

.uni-load-more__text {
  font-size: 30rpx;
}

.uni-load-more__img {
  width: 24px;
  height: 24px;
  margin-right: 8px;
}

.uni-load-more__img--ios-H5 {
  position: relative;
  animation: loading-ios-H5 1s step-end infinite;
}

.uni-load-more__img--ios-H5 image {
  position: absolute;
  width: 100%;
  height: 100%;
  left: 0;
  top: 0;
}

.uni-load-more__img--android-MP {
  position: relative;
  width: 24px;
  height: 24px;
  animation: loading-ios 1s ease infinite;
}

.uni-load-more__img--android-MP > view {
  position: absolute;
  box-sizing: border-box;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: solid 2px transparent;
  border-top: solid 2px #777777;
  transform-origin: center;
}

@keyframes loading-ios-H5 {
  0% { transform: rotate(0deg); }
  8% { transform: rotate(30deg); }
  16% { transform: rotate(60deg); }
  24% { transform: rotate(90deg); }
  32% { transform: rotate(120deg); }
  40% { transform: rotate(150deg); }
  48% { transform: rotate(180deg); }
  56% { transform: rotate(210deg); }
  64% { transform: rotate(240deg); }
  73% { transform: rotate(270deg); }
  82% { transform: rotate(300deg); }
  91% { transform: rotate(330deg); }
  100% { transform: rotate(360deg); }
}

@keyframes loading-ios {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
